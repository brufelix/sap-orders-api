# Server
PORT=8081
ENV=development

# Database
DATABASE_URL=postgres://saporders:saporders@localhost:5434/saporders?sslmode=disable

# Microsoft Entra ID (Azure AD) — access tokens
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-api-client-id
AZURE_AUDIENCE=api://your-api-client-id

# TLS (required when ENV=production outside Railway)
TLS_CERT_FILE=
TLS_KEY_FILE=
TLS_REDIRECT=false
TLS_TERMINATED_AT_EDGE=false

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SEC=60
MAX_BODY_BYTES=1048576

# SAP RFC
SAP_RFC_FUNCTION=Z_UPDATE_DEMAND
SAP_RFC_ENABLED=false
